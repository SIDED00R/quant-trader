# 복사해서 .env 로 사용하세요: cp .env.example .env
# .env 는 .gitignore 에 의해 커밋되지 않습니다.
#
# ⚠️ 아래 값은 로컬 개발 전용 더미입니다. 운영(GCP 등)에서는 반드시
#    강한 비밀번호를 별도로 설정하고, 절대 레포에 커밋하지 마세요.
#    로컬 컨테이너 포트는 127.0.0.1(루프백)에만 바인딩됩니다.

# ── Kafka ──────────────────────────────────────────────
# 루프백 바인딩(127.0.0.1)이라 localhost 대신 127.0.0.1 사용(Windows의 ::1 회피)
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_pw          # 운영에서는 반드시 변경
POSTGRES_DB=coin_trading
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ── ClickHouse ─────────────────────────────────────────
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=ch_pw             # dev 더미, 운영에서는 반드시 변경
CLICKHOUSE_DB=coin_analytics
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_HTTP_PORT=8123

# ── 웹 대시보드 (주문 API 포함) ─────────────────────────
# API_BIND: 컨테이너 8000 포트를 바인딩할 호스트.
#   외부 공개는 Caddy(HTTPS)가 담당하므로 비워둔다 → 127.0.0.1(루프백, SSH 터널용).
#   8000 을 직접 인터넷에 노출할 필요는 없다. 인증은 아래 구글 OAuth 사용.
# API_BIND=

# ── 공개 HTTPS (Caddy) ─────────────────────────────────
# SITE_ADDRESS: Caddy가 인증서를 발급/서비스할 공개 도메인.
#   VM 공개: 도메인 지정(예: jh-quantlab.duckdns.org) → https:// 자동 발급.
#   로컬/미설정: 비워두면 :80(평문 HTTP)로 동작.
#   (api 의 OAuth redirect_uri = https://$SITE_ADDRESS/auth/callback 구성에도 사용)
# SITE_ADDRESS=jh-quantlab.duckdns.org

# ── 구글 OAuth 로그인 ──────────────────────────────────
# GOOGLE_CLIENT_ID/SECRET 둘 다 설정되면 OAuth 인증 활성(미설정 시 비활성, 로컬 개발).
# Google Cloud Console > APIs & Services > Credentials 에서 발급.
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxxx
# 로그인 허용 이메일(쉼표 구분). 신원확인≠권한부여 — 반드시 본인 계정으로 제한.
# ALLOWED_EMAILS=you@gmail.com,friend@gmail.com
# 세션 쿠키 서명 키 — 운영에서는 강한 무작위 값(openssl rand -hex 32).
# SESSION_SECRET=change-me
# 신규 계정 초기 가상자금(원)
# INITIAL_BALANCE=10000000

# ── 거래 종목 / 자동매매 전략 ─────────────────────────
# SUBSCRIBE_ALL_KRW: true면 업비트 전체 KRW 마켓(~180개) 동적 구독(SYMBOLS 무시).
# SUBSCRIBE_ALL_KRW=false
# SYMBOLS: 정적 종목 목록(SUBSCRIBE_ALL_KRW=false일 때). 비우면 기본 5종목.
# SYMBOLS=KRW-BTC,KRW-ETH,KRW-XRP,KRW-SOL,KRW-DOGE
# 매수 1회 = 현재 현금 × (신호강도 비례 비율). 약신호→MIN, 강신호→MAX.
# STRATEGY_ORDER_FRACTION_MIN=0.05
# STRATEGY_ORDER_FRACTION_MAX=0.20
# STRATEGY_STRONG_GAP=0.015          # 이평선 간격이 이 비율 이상이면 MAX 비중
# STRATEGY_MAX_POSITIONS=10          # 계정당 동시 보유 종목 수 상한
#
# ── 거래빈도·수수료 제어 (1.5단계) ──
# 아래 가드 기본값은 1분봉 기준으로 재튜닝됨(백테스트 sma/disciplined 전략용 —
# 과거 라이브 SMA 틱봇은 앙상블 경로로 대체·제거됨).
# STRATEGY_COOLDOWN_SEC=3600         # (계정,종목) 재진입 쿨다운(초). 1분봉 기준 60봉=1h
# STRATEGY_MIN_HOLD_SEC=1800         # 데드크로스 청산 최소보유(초). 1분봉 기준 30봉
# STRATEGY_WARMUP_SEC=1500           # 기동 후 진입/데드크로스 보류(초). 1분봉 기준 25봉
# STRATEGY_MIN_EDGE_PCT=0.005        # 수수료 인지 진입 필터: 신호강도(이평선 간격) 하한. 왕복 수수료(~0.1%)보다 충분히 크게
# STRATEGY_DEADCROSS_EXIT=false      # 데드크로스 청산 사용 여부(기본 off — baseline 최대 출혈원). STOP/TAKE/TRAIL만으로 청산

# ── 키움증권 주식 (7단계: 주식 확장) ────────────────────
# 키움 신규 REST API 자격증명: openapi.kiwoom.com 'API 사용신청'에서 발급(PC 브라우저 전용).
# 모의(mock)·실전(real) 공통 키. KIWOOM_MOCK 으로 도메인 전환(mockapi ↔ api).
# stock-ingester(수집)는 APP_KEY/SECRET 만 필요(체결은 KIS 채택 — 키움은 데이터 전용).
# KIWOOM_MOCK=true                   # true=모의(mockapi.kiwoom.com), false=실전(api.kiwoom.com)
# KIWOOM_APP_KEY=발급_appkey
# KIWOOM_APP_SECRET=발급_secretkey
# STOCK_SYMBOLS: 잠정 데이터 수집 대상(운용 유니버스는 8단계 백테스트 후 확정). 6자리 종목코드.
# STOCK_SYMBOLS=005930,000660

# ── 토스증권 (주식 일봉/분봉 데이터 소스) ───────────────
# openapi.tossinvest.com 발급. 데이터 전용(체결 미지원).
# TOSS_CLIENT_ID=발급_client_id
# TOSS_CLIENT_SECRET=발급_client_secret

# ── 한국투자증권 KIS (주식 체결: KR+US 통합 모의/실전) ───
# KIS Developers(apiportal.koreainvestment.com)에서 appkey/appsecret 발급.
# KIS_MOCK=true                      # true=모의(모의투자), false=실전
# KIS_APPKEY=발급_appkey
# KIS_APPSECRET=발급_appsecret
# KIS_ACCOUNT_NO=00000000-01         # 계좌번호 'CANO-PRDT'(앞 8자리-상품코드 2자리)

# ── FRED 매크로 (batch.rawdata.fred) ──────────────────────
# fred.stlouisfed.org 무료 API 키. 일별 매크로 시계열 수집용(월간 유지보수 스텝).
# FRED_API_KEY=발급_api_key

# ── KRX 로그인 (batch.rawdata.krx·kr_index_membership) ─────
# data.krx.co.kr 계정. 수급·공매도·외국인보유·지수구성 통계는 로그인 필수(pykrx 1.2.8+).
# 월간 유지보수 스텝이 증분 수집에 사용 — 미설정 시 해당 스텝만 🔴(다른 스텝 무영향).
# KRX_ID=아이디
# KRX_PW=비밀번호

# ── DART 펀더멘털 (batch.rawdata.kr_fundamentals) ──────────
# opendart.fss.or.kr 무료 API 키. KR 분기 재무(펀더멘털 ML 피처) 수집용 — 미설정 시 수집기가 RuntimeError.
# DART_API_KEY=발급_api_key

# ── 텔레그램 매매 알림 (MTProto 사용자 계정 — Telethon) ──
# my.telegram.org 에서 api_id/api_hash 발급 → python -m scripts.telegram_login 1회 실행으로
# TELEGRAM_SESSION(StringSession) 발급. 미설정이면 발송이 조용히 스킵된다(매매엔 영향 없음).
# 운영(매매 VM)은 Secret Manager `telegram-env`로 주입 — 여기(.env)엔 로컬 테스트 값만.
# TELEGRAM_API_ID=발급_api_id
# TELEGRAM_API_HASH=발급_api_hash
# TELEGRAM_SESSION=telegram_login_출력값
# TELEGRAM_TARGET=me                 # 수신 대상(기본 me = 나에게 보내기/저장된 메시지)
# ── 텔레그램 /차트 봇 (인바운드 — BotFather 봇, 발신용 유저세션과 분리) ──
# BotFather로 봇 생성 → 토큰. 본인이 봇에게 /start 후 getUpdates로 chat_id 확인 → 화이트리스트.
# 운영(수집 VM)은 telegram-env 시크릿에 함께 주입(^TELEGRAM_ prefix 병합).
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_ALLOWED_CHAT_IDS=123456789   # 쉼표구분, 비면 전면 거부
