# 복사해서 .env 로 사용하세요: cp .env.example .env
# .env 는 .gitignore 에 의해 커밋되지 않습니다.
#
# ⚠️ 아래 값은 로컬 개발 전용 더미입니다. 운영(GCP 등)에서는 반드시
#    강한 비밀번호를 별도로 설정하고, 절대 레포에 커밋하지 마세요.
#    로컬 컨테이너 포트는 127.0.0.1(루프백)에만 바인딩됩니다.

# ── Kafka ──────────────────────────────────────────────
# 루프백 바인딩(127.0.0.1)이라 localhost 대신 127.0.0.1 사용(Windows의 ::1 회피)
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_pw          # 운영에서는 반드시 변경
POSTGRES_DB=coin_trading
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ── ClickHouse ─────────────────────────────────────────
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=ch_pw             # dev 더미, 운영에서는 반드시 변경
CLICKHOUSE_DB=coin_analytics
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_HTTP_PORT=8123

# ── 웹 대시보드 (주문 API 포함) ─────────────────────────
# API_BIND: 컨테이너 8000 포트를 바인딩할 호스트.
#   외부 공개는 Caddy(HTTPS)가 담당하므로 비워둔다 → 127.0.0.1(루프백, SSH 터널용).
#   8000 을 직접 인터넷에 노출할 필요는 없다.
# API_BIND=
#
# WEB_PASSWORD: 비어 있으면 인증 비활성(로컬). 외부 공개 시 반드시 강한 값 설정.
WEB_USER=admin
WEB_PASSWORD=

# ── 공개 HTTPS (Caddy) ─────────────────────────────────
# SITE_ADDRESS: Caddy가 인증서를 발급/서비스할 공개 도메인.
#   VM 공개: 도메인 지정(예: jh-coinlab.duckdns.org) → https:// 자동 발급.
#   로컬/미설정: 비워두면 :80(평문 HTTP)로 동작.
# SITE_ADDRESS=jh-coinlab.duckdns.org
